{
  "_meta": {
    "description": "Head vocabulary for EVEE. Single source of truth for display names, grouping, curation rules, and predictor config. Consumed by the build step to produce heads.json for the frontend.",
    "quality_thresholds": {
      "min_auprc": 0.7,
      "min_mcc": 0.3,
      "min_spearman": 0.4,
      "min_samples": 100
    },
    "removed_categories": [
      "codon",
      "trinuc",
      "syn",
      "gtex"
    ],
    "removed_exact": [
      "gc_content"
    ],
    "tissue_specific_pattern": "^(chipseq|atacseq|chromhmm)_.*(?<!_breadth)(?<!_count)$",
    "attribution_dedup": {
      "chromhmm_states": [
        "active_tss",
        "bivalent",
        "enhancer",
        "heterochromatin",
        "polycomb",
        "quiescent",
        "transcribed",
        "weak_enhancer",
        "weak_transcription"
      ],
      "description": "ChromHMM heads are deduplicated by state (e.g., chromhmm_{tissue}_{state} -> chromhmm_{state}). ChIP-seq by mark+type. ATAC-seq by type. fstack heads collapse to one group."
    },
    "curated_disruption_groups": [
      "Protein",
      "Structure",
      "Regulatory",
      "Domains",
      "ELM Motifs",
      "Amino Acid",
      "PTM",
      "Region"
    ],
    "curated_effect_groups": [
      "Substitution",
      "Variant Effects",
      "Pfam Domains"
    ],
    "effect_group_tokens": {
      "Substitution": [
        "aa",
        "blosum62",
        "grantham",
        "hydrophobicity",
        "volume",
        "mw"
      ],
      "Variant Effects": [
        "splice",
        "charge",
        "consequence",
        "impact",
        "csq"
      ],
      "Pfam Domains": [
        "pfam"
      ]
    },
